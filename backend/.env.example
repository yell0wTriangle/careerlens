NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

MONGO_URI=mongodb://127.0.0.1:27017/careerlens

ACCESS_TOKEN_SECRET=replace-with-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=15
EMAIL_QUEUE_ENABLED=true

# Email transport: "console" (logs code in backend terminal) or "smtp" (sends real email)
EMAIL_TRANSPORT=console
EMAIL_FROM=no-reply@careerlens.local
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_RESUME_BUCKET=resumes
